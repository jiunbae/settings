#!/bin/bash
# docs-push - Push markdown files to docs server
# Usage:
#   docs-push ./article.md           # Push single file
#   docs-push ./folder/              # Push directory
#   docs-push --list                 # List published docs
#   docs-push --delete article.md    # Delete a published doc
#   docs-push --open article         # Open in browser
set -euo pipefail

DOCS_HOST="192.168.32.70"
DOCS_USER="root"
DOCS_ROOT="/var/www/docs"
DOCS_URL="https://docs.jiun.dev"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
    echo "Usage: docs-push [OPTIONS] <file-or-directory>"
    echo ""
    echo "Commands:"
    echo "  <file.md>          Push a markdown file"
    echo "  <directory/>       Push all markdown files in directory"
    echo "  --list, -l         List published documents"
    echo "  --delete, -d FILE  Delete a published document"
    echo "  --open, -o NAME    Open document in browser"
    echo "  --help, -h         Show this help"
}

list_docs() {
    echo -e "${CYAN}Published documents:${NC}"
    ssh "${DOCS_USER}@${DOCS_HOST}" \
        "find ${DOCS_ROOT} -name '*.md' -not -name '_sidebar.md' -not -name 'index.md' | sort" | \
    while read -r path; do
        rel="${path#${DOCS_ROOT}/}"
        name="${rel%.md}"
        echo -e "  ${GREEN}${rel}${NC}  →  ${DOCS_URL}/#/${name}"
    done
}

delete_doc() {
    local target="$1"
    # Add .md if not present
    [[ "$target" != *.md ]] && target="${target}.md"
    echo -e "${RED}Deleting${NC} ${target}..."
    ssh "${DOCS_USER}@${DOCS_HOST}" "rm -f '${DOCS_ROOT}/${target}'"
    echo -e "${GREEN}Deleted.${NC} Sidebar will auto-regenerate."
}

open_doc() {
    local name="$1"
    [[ "$name" == *.md ]] && name="${name%.md}"
    open "${DOCS_URL}/#/${name}" 2>/dev/null || \
        echo "${DOCS_URL}/#/${name}"
}

push_files() {
    local src="$1"

    if [ -f "$src" ]; then
        # Single file
        local basename=$(basename "$src")
        echo -e "${CYAN}Pushing${NC} ${basename}..."
        rsync -az --progress "$src" "${DOCS_USER}@${DOCS_HOST}:${DOCS_ROOT}/${basename}"
        local name="${basename%.md}"
        echo -e "${GREEN}Published:${NC} ${DOCS_URL}/#/${name}"
    elif [ -d "$src" ]; then
        # Directory - preserve structure
        echo -e "${CYAN}Pushing${NC} ${src}..."
        rsync -az --progress \
            --include='*/' \
            --include='*.md' \
            --include='*.png' \
            --include='*.jpg' \
            --include='*.jpeg' \
            --include='*.gif' \
            --include='*.svg' \
            --exclude='*' \
            "$src" "${DOCS_USER}@${DOCS_HOST}:${DOCS_ROOT}/"
        echo -e "${GREEN}Published:${NC} ${DOCS_URL}/#/"
    else
        echo -e "${RED}Error:${NC} ${src} not found"
        exit 1
    fi

    # Trigger sidebar regeneration
    ssh "${DOCS_USER}@${DOCS_HOST}" "/usr/local/bin/update-sidebar" 2>/dev/null || true
}

# Parse arguments
case "${1:-}" in
    --help|-h|"")
        usage
        exit 0
        ;;
    --list|-l)
        list_docs
        ;;
    --delete|-d)
        [ -z "${2:-}" ] && { echo "Error: specify file to delete"; exit 1; }
        delete_doc "$2"
        ;;
    --open|-o)
        [ -z "${2:-}" ] && { echo "Error: specify document name"; exit 1; }
        open_doc "$2"
        ;;
    *)
        push_files "$1"
        ;;
esac
